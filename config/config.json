{
  "paths": {
    "input": "data/input",
    "processed": "data/processed",
    "quarantine": "data/quarantine",
    "logs": "output/logs",
    "reports": "output/reports"
  },

  "structure": {
    "quarantine_subfolders": [
      "invalid_filename",
      "invalid_extension",
      "invalid_both"
    ],

    "use_category_subfolders": true
  },

  "archive": {
    "enabled": true,
    "days_threshold": 30,
    "subfolder_name": "archive"
  },

  "validation": {
    "filename_pattern": "^[a-z]+(_[a-z]+)*(_[0-9]+)?$",
    "extensions": {
      "text": ["txt", "md"],
      "audio": ["mp3", "midi"],
      "video": ["mp4", "webm"],
      "images": ["jpg", "png"],
      "documents": ["pdf", "docx"]
    }
  }
}