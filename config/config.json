{
  "paths": {
    "input": "data/input",
    "processed": "data/processed",
    "quarantine": "data/quarantine",
    "archive": "data/archive",
    "logs": "output/logs",
    "reports": "output/reports"
  },
  "validation": {
    "filename_pattern": "^[a-z]+(_[a-z]+)*([0-9]+)?$",
    "extensions": {
      "text": ["txt", "md"],
      "audio": ["mp3", "midi"],
      "video": ["mp4, webm"],
      "images": ["jpg", "png"],
      "documents": ["pdf","docx"]
    }
  }
}